{
  "name": "league-bulk-buy",
  "version": "1.0.0",
  "description": "Bulk buy tool for League of Legends",
  "author": "Lei",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite preview",
    "build": "electron-vite build",
    "preview": "cross-env NODE_ENV=production electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "element-plus": "^2.13.6",
    "pinia": "^2.2.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "@vueuse/core": "^14.2.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "@types/node": "^22.0.0",
    "cross-env": "^7.0.3",
    "electron": "^32.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^5.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.1.0"
  },
  "build": {
    "appId": "com.lei.league-bulk-buy",
    "productName": "League Bulk Buy",
    "asar": false,
    "npmRebuild": false,
    "directories": {
      "buildResources": "resources"
    },
    "extraFiles": [
      {
        "from": "vendor",
        "to": "resources/vendor"
      }
    ],
    "files": [
      "out/**",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "League Bulk Buy"
    }
  }
}